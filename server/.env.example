# ── Apps Script ───────────────────────────────────────────────
# URL ที่ได้หลัง Deploy Web App ใน Google Apps Script
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ต้องตรงกับ SECRET_TOKEN ใน apps-script-auth.js
APPS_SCRIPT_TOKEN=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ── Turso / libSQL ────────────────────────────────────────────
# ปล่อยว่างได้ถ้าต้องการรันแบบ local only
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── JWT ───────────────────────────────────────────────────────
# สร้าง random secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
